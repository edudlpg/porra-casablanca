generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum ScoreType {
  EXACT
  GOAL_DIFFERENCE
  FINAL_RESULT
  FAILED
  PENDING
}

enum BroadcastPartner {
  DAZN
  RTVE
}

model User {
  id           String       @id @default(cuid())
  name         String
  username     String?      @unique
  email        String?      @unique
  avatarUrl    String?
  passwordHash String
  role         Role         @default(USER)
  createdAt    DateTime     @default(now())
  predictions  Prediction[]
}

model AppConfig {
  id         String   @id @default("singleton")
  entryFee   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Round {
  id        String   @id @default(cuid())
  name      String   @unique
  unlockAt  DateTime @default(now())
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now())
  matches   Match[]
}

model Team {
  id             String  @id @default(cuid())
  name           String  @unique
  flagUrl        String?
  homeMatches    Match[] @relation("HomeTeamMatches")
  awayMatches    Match[] @relation("AwayTeamMatches")
}

model Match {
  id          String       @id @default(cuid())
  roundId     String
  homeTeamId  String
  awayTeamId  String
  venueName   String?
  venueCity   String?
  startsAt    DateTime
  homeScore   Int?
  awayScore   Int?
  broadcast   BroadcastPartner @default(DAZN)
  isLocked    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  round       Round        @relation(fields: [roundId], references: [id], onDelete: Cascade)
  homeTeam    Team         @relation("HomeTeamMatches", fields: [homeTeamId], references: [id], onDelete: Restrict)
  awayTeam    Team         @relation("AwayTeamMatches", fields: [awayTeamId], references: [id], onDelete: Restrict)
  predictions Prediction[]

  @@index([roundId, startsAt])
}

model Prediction {
  id                  String    @id @default(cuid())
  userId              String
  matchId             String
  predictedHomeScore  Int
  predictedAwayScore  Int
  points              Int       @default(0)
  scoreType           ScoreType @default(PENDING)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  match               Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
  @@index([matchId])
  @@index([userId])
}
