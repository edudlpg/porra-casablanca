{
  "name": "porra-casablanca",
  "version": "1.0.0",
  "description": "Webapp mobile-first para gestionar una porra del Mundial",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "node --import tsx/esm prisma/seed.ts",
    "prisma:backfill:broadcasts": "node --import tsx/esm prisma/backfill-match-broadcasts.ts"
  },
  "keywords": [
    "nextjs",
    "prisma",
    "porra",
    "world-cup"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/postcss": "^4.3.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.20.0",
    "postcss": "^8.5.14",
    "prisma": "^7.8.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "prisma": {
    "seed": "node --import tsx/esm prisma/seed.ts"
  }
}
